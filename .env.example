# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=disable

# Session
SESSION_SECRET=your-session-secret-min-32-chars

# --- VPS storage (recommended on VPS) ---
# Use local filesystem for uploads. See docs/SETUP_VPS_STORAGE.md
FILE_STORAGE_MODE=local
# Absolute path for production. Omit to use ./uploads inside project.
# Examples: /var/www/storage  or  /var/www/Dhagasingh_SCM/uploads
# UPLOADS_DIR=/var/www/storage

# --- Replit storage (only when running on Replit) ---
# Do NOT set these on VPS when using FILE_STORAGE_MODE=local
# REPL_ID=
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=
